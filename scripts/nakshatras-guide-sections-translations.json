    "guides.nakshatras.sections.completeList": {
      "en": "Complete List of 27 Nakshatras",
      "hi": "27 नक्षत्रों की पूर्ण सूची",
      "ta": "27 நட்சத்திரங்களின் முழுமையான பட்டியல்",
      "te": "27 నక్షత్రాల పూర్తి జాబితా",
      "bn": "27 নক্ষত্রের সম্পূর্ণ তালিকা",
      "mr": "27 नक्षत्रांची संपूर्ण यादी",
      "gu": "27 નક્ષત્રોની સંપૂર્ણ સૂચિ",
      "kn": "27 ನಕ್ಷತ್ರಗಳ ಸಂಪೂರ್ಣ ಪಟ್ಟಿ",
      "ml": "27 നക്ഷത്രങ്ങളുടെ പൂര്‍ണ്ണ പട്ടിക",
      "pa": "27 ਨਕਸ਼ਤਰਾਂ ਦੀ ਪੂਰੀ ਸੂਚੀ"
    },
    "guides.nakshatras.sections.detailedDescriptions": {
      "en": "Detailed Nakshatra Descriptions",
      "hi": "विस्तृत नक्षत्र विवरण",
      "ta": "விரிவான நட்சத்திர விவரணைகள்",
      "te": "వివరమైన నక్షత్ర వివరణలు",
      "bn": "বিস্তারিত নক্ষত্র বর্ণনা",
      "mr": "तपशीलवार नक्षत्र वर्णन",
      "gu": "વિગતવાર નક્ષત્ર વર્ણન",
      "kn": "ವಿವರವಾದ ನಕ್ಷತ್ರ ವಿವರಣೆಗಳು",
      "ml": "വിശദമായ നക്ഷത്ര വിവരണങ്ങള്‍",
      "pa": "ਵਿਸਤ੍ਰਿਤ ਨਕਸ਼ਤਰ ਵਰਣਨ"
    },
    "guides.nakshatras.sections.understandingGroups": {
      "en": "Understanding Nakshatra Groups",
      "hi": "नक्षत्र समूहों को समझना",
      "ta": "நட்சத்திர குழுக்களைப் புரிந்துகொள்ளுதல்",
      "te": "నక్షత్ర సమూహాలను అర్థం చేసుకోవడం",
      "bn": "নক্ষত্র গোষ্ঠী বোঝা",
      "mr": "नक्षत्र गटांना समजून घेणे",
      "gu": "નક્ષત્ર જૂથોને સમજવું",
      "kn": "ನಕ್ಷತ್ರ ಗುಂಪುಗಳನ್ನು ಅರ್ಥಮಾಡಿಕೊಳ್ಳುವುದು",
      "ml": "നക്ഷത്ര ഗ്രൂപ്പുകള്‍ മനസ്സിലാക്കുക",
      "pa": "ਨਕਸ਼ਤਰ ਸਮੂਹਾਂ ਨੂੰ ਸਮਝਣਾ"
    },
    "guides.nakshatras.sections.faq": {
      "en": "Frequently Asked Questions",
      "hi": "अक्सर पूछे जाने वाले प्रश्न",
      "ta": "அடிக்கடி கேட்கப்படும் கேள்விகள்",
      "te": "తరచుగా అడిగే ప్రశ్నలు",
      "bn": "প্রায়শই জিজ্ঞাসিত প্রশ্নাবলী",
      "mr": "वारंवार विचारले जाणारे प्रश्न",
      "gu": "વારંવાર પૂછાતા પ્રશ્નો",
      "kn": "ಪದೇ ಪದೇ ಕೇಳಲಾಗುವ ಪ್ರಶ್ನೆಗಳು",
      "ml": "പതിവായി ചോദിക്കുന്ന ചോദ്യങ്ങള്‍",
      "pa": "ਅਕਸਰ ਪੁੱਛੇ ਜਾਣ ਵਾਲੇ ਸਵਾਲ"
    },
