{
  "section": "horoscope",
  "keys": {
    "selectYourSign": {
      "en": "Select Your Zodiac Sign",
      "hi": "अपनी राशि चुनें",
      "ta": "உங்கள் ராசியை தேர்ந்தெடுக்கவும்",
      "te": "మీ రాశిని ఎంచుకోండి",
      "bn": "আপনার রাশি নির্বাচন করুন",
      "mr": "तुमची राशी निवडा",
      "gu": "તમારી રાશિ પસંદ કરો",
      "kn": "ನಿಮ್ಮ ರಾಶಿಯನ್ನು ಆಯ್ಕೆಮಾಡಿ",
      "ml": "നിങ്ങളുടെ രാശി തിരഞ്ഞെടുക്കുക",
      "pa": "ਆਪਣੀ ਰਾਸ਼ੀ ਚੁਣੋ"
    },
    "clickToView": {
      "en": "Click on your zodiac sign above to view your personalized daily horoscope.",
      "hi": "अपनी व्यक्तिगत दैनिक राशिफल देखने के लिए ऊपर अपनी राशि पर क्लिक करें।",
      "ta": "உங்கள் தனிப்பயனாக்கப்பட்ட தினசரி ஜாதகத்தைப் பார்க்க மேலே உங்கள் ராசியைக் கிளிக் செய்யவும்.",
      "te": "మీ వ్యక్తిగత రోజువారీ జాతకాన్ని చూడటానికి పైన మీ రాశిపై క్లిక్ చేయండి.",
      "bn": "আপনার ব্যক্তিগত দৈনিক রাশিফল দেখতে উপরে আপনার রাশিতে ক্লিক করুন।",
      "mr": "तुमची वैयक्तिक दैनिक राशिभविष्य पाहण्यासाठी वरील तुमच्या राशीवर क्लिक करा.",
      "gu": "તમારી વ્યક્તિગત દૈનિક રાશિફળ જોવા માટે ઉપર તમારી રાશિ પર ક્લિક કરો.",
      "kn": "ನಿಮ್ಮ ವೈಯಕ್ತಿಕ ದೈನಂದಿನ ರಾಶಿಫಲವನ್ನು ವೀಕ್ಷಿಸಲು ಮೇಲಿನ ನಿಮ್ಮ ರಾಶಿಯ ಮೇಲೆ ಕ್ಲಿಕ್ ಮಾಡಿ.",
      "ml": "നിങ്ങളുടെ വ്യക്തിഗത ദൈനംദിന രാശിഫലം കാണാന്‍ മുകളിലുള്ള നിങ്ങളുടെ രാശിയില്‍ ക്ലിക്ക് ചെയ്യുക.",
      "pa": "ਆਪਣੀ ਨਿੱਜੀ ਰੋਜ਼ਾਨਾ ਰਾਸ਼ੀਫਲ ਦੇਖਣ ਲਈ ਉੱਪਰ ਆਪਣੀ ਰਾਸ਼ੀ 'ਤੇ ਕਲਿੱਕ ਕਰੋ।"
    },
    "wantDetailedReading": {
      "en": "Want a more detailed and personalized reading based on your exact birth chart?",
      "hi": "अपनी सटीक जन्म कुंडली के आधार पर अधिक विस्तृत और व्यक्तिगत पठन चाहते हैं?",
      "ta": "உங்கள் சரியான ஜாதகத்தின் அடிப்படையில் மேலும் விரிவான மற்றும் தனிப்பயனாக்கப்பட்ட வாசிப்பு வேண்டுமா?",
      "te": "మీ ఖచ్చితమైన జన్మ చార్ట్ ఆధారంగా మరింత వివరణాత్మక మరియు వ్యక్తిగత పఠనం కావాలా?",
      "bn": "আপনার সঠিক জন্ম চার্টের উপর ভিত্তি করে আরও বিস্তারিত এবং ব্যক্তিগত পাঠ চান?",
      "mr": "तुमच्या अचूक जन्म कुंडलीवर आधारित अधिक तपशीलवार आणि वैयक्तिक वाचन हवे आहे?",
      "gu": "તમારી ચોક્કસ જન્મ કુંડળીના આધારે વધુ વિગતવાર અને વ્યક્તિગત વાંચન જોઈએ છે?",
      "kn": "ನಿಮ್ಮ ನಿಖರವಾದ ಜನ್ಮ ಚಾರ್ಟ್ ಆಧಾರಿತ ಹೆಚ್ಚು ವಿವರವಾದ ಮತ್ತು ವೈಯಕ್ತಿಕ ಓದುವಿಕೆ ಬೇಕೇ?",
      "ml": "നിങ്ങളുടെ കൃത്യമായ ജനന ചാര്‍ട്ടിനെ അടിസ്ഥാനമാക്കി കൂടുതല്‍ വിശദമായതും വ്യക്തിഗതമായതുമായ വായന വേണോ?",
      "pa": "ਤੁਹਾਡੀ ਸਹੀ ਜਨਮ ਕੁੰਡਲੀ ਦੇ ਆਧਾਰ 'ਤੇ ਵਧੇਰੇ ਵਿਸਤ੍ਰਿਤ ਅਤੇ ਨਿੱਜੀ ਪੜ੍ਹਾਈ ਚਾਹੁੰਦੇ ਹੋ?"
    },
