    },
    "transits.saturn.remedies.remedy8.title": {
      "en": "Oil to Shani",
      "hi": "शनि को तेल चढ़ाएं",
      "ta": "சனிக்கு எண்ணெய் ஊற்றுங்கள்",
      "te": "శనికి నూనె అర్పించండి",
      "bn": "শনিকে তেল দিন",
      "mr": "शनीला तेल अर्पण करा",
      "gu": "શનિને તેલ ચઢાવો",
      "kn": "ಶನಿಗೆ ಎಣ್ಣೆ ಅರ್ಪಿಸಿ",
      "ml": "ശനിക്ക് എണ്ണ അർപ്പിക്കുക",
      "pa": "ਸ਼ਨੀ ਨੂੰ ਤੇਲ ਚੜ੍ਹਾਓ"
    },
    "transits.saturn.remedies.remedy8.description": {
      "en": "Offer mustard oil to Shani idol",
      "hi": "शनि मूर्ति को सरसों का तेल चढ़ाएं",
      "ta": "சனி சிலைக்கு கடுகு எண்ணெய் ஊற்றுங்கள்",
      "te": "శని విగ్రహానికి ఆవాల నూనె అర్పించండి",
      "bn": "শনি মূর্তিতে সরিষার তেল দিন",
      "mr": "शनि मूर्तीला मोहरीचे तेल अर्पण करा",
      "gu": "શનિ મૂર્તિને સરસવનું તેલ ચઢાવો",
