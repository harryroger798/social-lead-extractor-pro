{
  "section": "transits",
  "keys": {
    "transits.saturn.remedies.remedy1.title": {
      "en": "Shani Chalisa",
      "hi": "शनि चालीसा",
      "ta": "சனி சாலிசா",
      "te": "శని చాలీసా",
      "bn": "শনি চালিসা",
      "mr": "शनि चालीसा",
      "gu": "શનિ ચાલીસા",
      "kn": "ಶನಿ ಚಾಲೀಸಾ",
      "ml": "ശനി ചാലീസ",
      "pa": "ਸ਼ਨੀ ਚਾਲੀਸਾ"
    },
    "transits.saturn.remedies.remedy1.description": {
      "en": "Recite Shani Chalisa on Saturdays",
      "hi": "शनिवार को शनि चालीसा का पाठ करें",
      "ta": "சனிக்கிழமைகளில் சனி சாலிசா படிக்கவும்",
      "te": "శనివారాల్లో శని చాలీసా పఠించండి",
      "bn": "শনিবারে শনি চালিসা পাঠ করুন",
      "mr": "शनिवारी शनि चालीसा पठण करा",
      "gu": "શનિવારે શનિ ચાલીસા પાઠ કરો",
      "kn": "ಶನಿವಾರಗಳಂದು ಶನಿ ಚಾಲೀಸಾ ಪಠಿಸಿ",
      "ml": "ശനിയാഴ്ചകളിൽ ശനി ചാലീസ ചൊല്ലുക",
      "pa": "ਸ਼ਨੀਵਾਰ ਨੂੰ ਸ਼ਨੀ ਚਾਲੀਸਾ ਪਾਠ ਕਰੋ"
    },
    "transits.saturn.remedies.remedy2.title": {
      "en": "Donate to the needy",
      "hi": "जरूरतमंदों को दान करें",
      "ta": "ஏழைகளுக்கு தானம் செய்யுங்கள்",
      "te": "అవసరమైన వారికి దానం చేయండి",
      "bn": "দরিদ্রদের দান করুন",
      "mr": "गरजूंना दान करा",
      "gu": "જરૂરિયાતમંદોને દાન કરો",
      "kn": "ಅಗತ್ಯವಿರುವವರಿಗೆ ದಾನ ಮಾಡಿ",
      "ml": "ആവശ്യക്കാർക്ക് ദാനം ചെയ്യുക",
      "pa": "ਲੋੜਵੰਦਾਂ ਨੂੰ ਦਾਨ ਕਰੋ"
    },
    "transits.saturn.remedies.remedy2.description": {
      "en": "Donate black items on Saturdays",
      "hi": "शनिवार को काली वस्तुएं दान करें",
      "ta": "சனிக்கிழமைகளில் கருப்பு பொருட்களை தானம் செய்யுங்கள்",
      "te": "శనివారాల్లో నల్ల వస్తువులు దానం చేయండి",
      "bn": "শনিবারে কালো জিনিস দান করুন",
      "mr": "शनिवारी काळ्या वस्तू दान करा",
      "gu": "શનિવારે કાળી વસ્તુઓ દાન કરો",
      "kn": "ಶನಿವಾರಗಳಂದು ಕಪ್ಪು ವಸ್ತುಗಳನ್ನು ದಾನ ಮಾಡಿ",
      "ml": "ശനിയാഴ്ചകളിൽ കറുത്ത വസ്തുക്കൾ ദാനം ചെയ്യുക",
      "pa": "ਸ਼ਨੀਵਾਰ ਨੂੰ ਕਾਲੀਆਂ ਚੀਜ਼ਾਂ ਦਾਨ ਕਰੋ"
    },
    "transits.saturn.remedies.remedy3.title": {
      "en": "Shani Mantra",
      "hi": "शनि मंत्र",
      "ta": "சனி மந்திரம்",
      "te": "శని మంత్రం",
      "bn": "শনি মন্ত্র",
      "mr": "शनि मंत्र",
      "gu": "શનિ મંત્ર",
      "kn": "ಶನಿ ಮಂತ್ರ",
      "ml": "ശനി മന്ത്രം",
      "pa": "ਸ਼ਨੀ ਮੰਤਰ"
    },
    "transits.saturn.remedies.remedy3.description": {
      "en": "Chant 'Om Sham Shanicharaya Namah' 108 times",
      "hi": "'ॐ शं शनैश्चराय नमः' 108 बार जाप करें",
      "ta": "'ஓம் ஷம் சனிச்சராய நமஹ' 108 முறை ஜபிக்கவும்",
      "te": "'ఓం శం శనైశ్చరాయ నమః' 108 సార్లు జపించండి",
      "bn": "'ওম শম শনৈশ্চরায় নমঃ' 108 বার জপ করুন",
      "mr": "'ॐ शं शनैश्चराय नमः' 108 वेळा जप करा",
      "gu": "'ઓમ શં શનૈશ્ચરાય નમઃ' 108 વાર જાપ કરો",
      "kn": "'ಓಂ ಶಂ ಶನೈಶ್ಚರಾಯ ನಮಃ' 108 ಬಾರಿ ಜಪಿಸಿ",
      "ml": "'ഓം ശം ശനൈശ്ചരായ നമഃ' 108 തവണ ജപിക്കുക",
      "pa": "'ਓਮ ਸ਼ੰ ਸ਼ਨੈਸ਼ਚਰਾਯ ਨਮਃ' 108 ਵਾਰ ਜਾਪ ਕਰੋ"
    },
    "transits.saturn.remedies.remedy4.title": {
      "en": "Blue Sapphire",
      "hi": "नीलम",
      "ta": "நீலக்கல்",
      "te": "నీలం",
      "bn": "নীলা",
      "mr": "नीलम",
      "gu": "નીલમ",
      "kn": "ನೀಲಮಣಿ",
      "ml": "നീലക്കല്ല്",
      "pa": "ਨੀਲਮ"
    },
    "transits.saturn.remedies.remedy4.description": {
      "en": "Wear Blue Sapphire after proper consultation",
      "hi": "उचित परामर्श के बाद नीलम धारण करें",
      "ta": "சரியான ஆலோசனைக்குப் பிறகு நீலக்கல் அணியுங்கள்",
      "te": "సరైన సంప్రదింపు తర్వాత నీలం ధరించండి",
      "bn": "সঠিক পরামর্শের পরে নীলা পরুন",
      "mr": "योग्य सल्ल्यानंतर नीलम घाला",
      "gu": "યોગ્ય પરામર્શ પછી નીલમ પહેરો",
      "kn": "ಸರಿಯಾದ ಸಮಾಲೋಚನೆಯ ನಂತರ ನೀಲಮಣಿ ಧರಿಸಿ",
      "ml": "ശരിയായ കൺസൾട്ടേഷനു ശേഷം നീലക്കല്ല് ധരിക്കുക",
      "pa": "ਸਹੀ ਸਲਾਹ ਤੋਂ ਬਾਅਦ ਨੀਲਮ ਪਹਿਨੋ"
    },
    "transits.saturn.remedies.remedy5.title": {
      "en": "Serve the elderly",
      "hi": "बुजुर्गों की सेवा करें",
      "ta": "முதியவர்களுக்கு சேவை செய்யுங்கள்",
      "te": "వృద్ధులకు సేవ చేయండి",
      "bn": "বয়স্কদের সেবা করুন",
      "mr": "वृद्धांची सेवा करा",
      "gu": "વૃદ્ધોની સેવા કરો",
      "kn": "ಹಿರಿಯರಿಗೆ ಸೇವೆ ಮಾಡಿ",
      "ml": "പ്രായമായവരെ സേവിക്കുക",
      "pa": "ਬਜ਼ੁਰਗਾਂ ਦੀ ਸੇਵਾ ਕਰੋ"
    },
    "transits.saturn.remedies.remedy5.description": {
      "en": "Help and respect elderly people",
      "hi": "बुजुर्गों की मदद और सम्मान करें",
      "ta": "முதியவர்களுக்கு உதவுங்கள் மற்றும் மரியாதை செய்யுங்கள்",
      "te": "వృద్ధులకు సహాయం చేయండి మరియు గౌరవించండి",
      "bn": "বয়স্কদের সাহায্য করুন এবং সম্মান করুন",
      "mr": "वृद्धांना मदत करा आणि आदर करा",
      "gu": "વૃદ્ધોને મદદ કરો અને આદર આપો",
      "kn": "ಹಿರಿಯರಿಗೆ ಸಹಾಯ ಮಾಡಿ ಮತ್ತು ಗೌರವಿಸಿ",
      "ml": "പ്രായമായവരെ സഹായിക്കുകയും ബഹുമാനിക്കുകയും ചെയ്യുക",
      "pa": "ਬਜ਼ੁਰਗਾਂ ਦੀ ਮਦਦ ਕਰੋ ਅਤੇ ਸਤਿਕਾਰ ਕਰੋ"
    },
    "transits.saturn.remedies.remedy6.title": {
