{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/hi/layout,_N_T_/hi/blog/layout,_N_T_/hi/blog/page,_N_T_/hi/blog"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/hi/blog/__PAGE__",
    "/hi/blog",
    "/hi",
    "/_index",
    "/_head"
  ]
}